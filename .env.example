# PHẦN NÀY CỦA CHUNG

# Chạy Server trên cổng nào (Mặc định: 3000)
PORT=3000

# Môi trường chạy (development, production)
NODE_ENV=

# SETUP FIREBASE ADMIN SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
 
# RIÊNG

# Cho tính năng sắp xếp lịch trình (Bá Thi)
# LocationIQ.com
LOCATIONIQ_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# JWT Auth Secret
JWT_SECRET=
JWT_EXPIRES_IN=