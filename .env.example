# Chạy Server trên cổng nào (Mặc định: 3000)
PORT=3000

# Môi trường chạy (development, production)
NODE_ENV=development

# JWT Auth Secret
JWT_SECRET="changeme_jwt_secret_key"
JWT_EXPIRES_IN="1d"

# firebase admin sdk
# Lấy từ Service Account Key (Firebase Console > Project Settings > Service accounts > Generate new private key)
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
LOCATIONIQ_KEY="---"