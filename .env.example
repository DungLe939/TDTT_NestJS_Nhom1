# Chạy Server trên cổng nào (Mặc định: 3000)
PORT=3000

# Môi trường chạy (development, production)
NODE_ENV=development

# JWT Auth Secret
JWT_SECRET="changeme_jwt_secret_key"
JWT_EXPIRES_IN="1d"

# firebase admin sdk
# Lấy từ Service Account Key (Firebase Console > Project Settings > Service accounts > Generate new private key)
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
LOCATIONIQ_KEY="---"

# Gemini API key (dùng cho OCR qua Gemini hoặc các chức năng AI khác)
GEMINI_API_KEY="your-gemini-api-key"

# OCR provider: "gemini" hoặc "local"
OCR_PROVIDER="gemini"

# Gemini OCR model
GEMINI_OCR_MODEL="gemini-2.5-flash"
GEMINI_OCR_MODELS="gemini-2.5-flash,gemini-3-flash"

# Translation Settings
TRANSLATION_DEVICE="cpu" # Đổi thành "cuda" nếu có card NVIDIA
TRANSLATION_ENABLE_SENTIMENT="false"

